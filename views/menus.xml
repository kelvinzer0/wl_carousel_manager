<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action: Open OpenAPI spec URL -->
    <record id="action_carousel_api_docs" model="ir.actions.act_url">
        <field name="name">OpenAPI Spec</field>
        <field name="url">/carousel/openapi.json</field>
        <field name="target">new</field>
    </record>

    <!-- Top-level menu: Carousel Manager -->
    <!-- Only show API Keys + API Docs. Slides are managed by wl_splide_carousel
         under Website > Splide Carousel. -->
    <menuitem id="menu_carousel_root"
              name="Carousel API"
              sequence="81"/>

    <!-- Submenu: API Keys -->
    <menuitem id="menu_carousel_api_keys"
              name="API Keys"
              parent="menu_carousel_root"
              action="carousel_api_key_action"
              sequence="10"/>

    <!-- Submenu: API Docs -->
    <menuitem id="menu_carousel_api_docs"
              name="API Documentation"
              parent="menu_carousel_root"
              action="action_carousel_api_docs"
              sequence="20"/>

</odoo>
